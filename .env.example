# ---- Network ----
# Somnia testnet — verified from docs.somnia.network/developer/network-info on 2026-05-28
SOMNIA_TESTNET_RPC_URL=https://api.infra.testnet.somnia.network/
SOMNIA_TESTNET_WS_URL=wss://api.infra.testnet.somnia.network/ws
SOMNIA_TESTNET_CHAIN_ID=50312
SOMNIA_EXPLORER_URL=https://shannon-explorer.somnia.network/
# Mainnet (for reference; we deploy testnet-first)
SOMNIA_MAINNET_RPC_URL=https://api.infra.mainnet.somnia.network/
SOMNIA_MAINNET_CHAIN_ID=5031

# ---- Deployer ----
# NEVER commit a real key. Use a throwaway testnet key.
DEPLOYER_PRIVATE_KEY=0x...

# ---- Somnia platform addresses (verified from docs.somnia.network/agents/invoking-agents/from-solidity) ----
# Testnet agent platform (SomniaAgents contract)
AGENT_PLATFORM_ADDRESS=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
# Mainnet equivalent (do not use until everything works on testnet)
AGENT_PLATFORM_ADDRESS_MAINNET=0x5E5205CF39E766118C01636bED000A54D93163E6
# Reactivity precompile (per docs.somnia.network/developer/reactivity/reactivity-onchain)
REACTIVITY_PRECOMPILE=0x0000000000000000000000000000000000000100

# ---- Agent IDs ----
# Look up live IDs at the agent registry: https://agents.somnia.network/
# (NOT a code generator as some earlier notes said — it's the on-chain agent browser)
# Verified IDs as of 2026-05-28:
AGENT_ID_JSON_API=13174292974160097713
AGENT_ID_PARSE_WEBSITE=12875401142070969085
# LLM Inference ID not published in the docs; copy from agents.somnia.network UI before first use
AGENT_ID_LLM_INFERENCE=

# ---- Demo scaffolding ----
MOCK_ISSUER_URL=https://your-mock-issuer.vercel.app
# Comma-separated; each returns the depegged price for deterministic basket confirmation
PRICE_BASKET_ENDPOINTS=https://...,https://...

# ---- Frontend (NEXT_PUBLIC_* is exposed to the browser; do not put secrets here) ----
NEXT_PUBLIC_SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network/
NEXT_PUBLIC_SOMNIA_CHAIN_ID=50312
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_POOL_ADDRESS=0x...
NEXT_PUBLIC_POLICY_ADDRESS=0x...
NEXT_PUBLIC_TREASURY_ADDRESS=0x...
NEXT_PUBLIC_ORACLE_ADDRESS=0x...

# ---- LI.FI (cross-chain deposits, optional/stretch) ----
NEXT_PUBLIC_LIFI_INTEGRATOR=sentinel
