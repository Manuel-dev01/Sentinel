# ---- Network ----
# Somnia testnet — verified from docs.somnia.network/developer/network-info on 2026-05-28
SOMNIA_TESTNET_RPC_URL=https://api.infra.testnet.somnia.network/
SOMNIA_TESTNET_WS_URL=wss://api.infra.testnet.somnia.network/ws
SOMNIA_TESTNET_CHAIN_ID=50312
SOMNIA_EXPLORER_URL=https://shannon-explorer.somnia.network/
# Mainnet (for reference; we deploy testnet-first)
SOMNIA_MAINNET_RPC_URL=https://api.infra.mainnet.somnia.network/
SOMNIA_MAINNET_CHAIN_ID=5031

# ---- Deployer ----
# NEVER commit a real key. Use a throwaway testnet key.
DEPLOYER_PRIVATE_KEY=0x...

# ---- Somnia platform addresses (verified from docs.somnia.network/agents/invoking-agents/from-solidity) ----
# Testnet agent platform (SomniaAgents contract)
AGENT_PLATFORM_ADDRESS=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
# Mainnet equivalent (do not use until everything works on testnet)
AGENT_PLATFORM_ADDRESS_MAINNET=0x5E5205CF39E766118C01636bED000A54D93163E6
# Reactivity precompile (per docs.somnia.network/developer/reactivity/reactivity-onchain)
REACTIVITY_PRECOMPILE=0x0000000000000000000000000000000000000100

# ---- Agent IDs ----
# Look up live IDs at the agent registry: https://agents.somnia.network/
# (NOT a code generator as some earlier notes said — it's the on-chain agent browser)
# Verified IDs as of 2026-05-28:
AGENT_ID_JSON_API=13174292974160097713
AGENT_ID_PARSE_WEBSITE=12875401142070969085
# LLM Inference ID (looked up from agents.somnia.network UI 2026-05-29)
# This particular agent is a Qwen3-30B-backed string-in-string-out inference primitive —
# payload is abi.encode(prompt) and response decodes to a single string. Used by the spike
# and by the production SentinelOracle classification stage.
AGENT_ID_LLM_INFERENCE=12847293847561029384

# ---- Demo scaffolding ----
# Public URL serving the mock issuer JSON (Next.js route at frontend/src/app/api/peg-status/route.ts).
# Deploy frontend/ to Vercel and paste the resulting URL here, e.g.
#   https://sentinel-issuer.vercel.app/api/peg-status
# Used by BOTH the Step-3 spike AND the M6 Oracle confirm stage (JSON API agent reads `price_wad`,
# an integer-WAD price string, with decimals=0). Deploy/spike refuse to run if unset.
MOCK_ISSUER_URL=

# Public URL of the mock issuer HTML incident page (Next.js page at frontend/src/app/issuer/incident).
# This is the LLM Parse Website (Agent #2) target — deploy.ts registers it as the stable's homepageUrl.
# Defaults to MOCK_ISSUER_URL if unset, but the dedicated page reads better for the agent + the demo:
#   https://sentinel-issuer.vercel.app/issuer/incident
ISSUER_PAGE_URL=

# ---- M6 deploy / demo knobs (all optional; sensible defaults in script/deploy.ts) ----
# Native STT parked in SentinelOracle: >=32 for the subscription owner minimum + agent-request budget.
ORACLE_FUNDING_STT=34
# LP capital seeded into the pool (sUSD, human units).
POOL_SEED=1000000
# Demo policy notional (USDC, human units) and term.
POLICY_NOTIONAL=100000
POLICY_TERM_DAYS=365
# Price USDC is pushed to in simulate-depeg.ts (peg is $1.00); 0.92 = 800bps depeg = top tier.
DEPEG_PRICE=0.92

# Comma-separated; each returns the depegged price for deterministic basket confirmation
PRICE_BASKET_ENDPOINTS=https://...,https://...

# ---- Frontend (NEXT_PUBLIC_* is exposed to the browser; do not put secrets here) ----
NEXT_PUBLIC_SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network/
NEXT_PUBLIC_SOMNIA_CHAIN_ID=50312
# WalletConnect/Reown project id — REQUIRED for WalletConnect-based wallets in the dApp.
# Injected wallets (MetaMask) work without it, but set a real id from https://cloud.reown.com
# before the demo/deploy or the connect modal falls back to a non-functional placeholder.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Contract addresses are baked into frontend/src/lib/generated.ts (from the latest deploy);
# only set these to OVERRIDE after a redeploy (then also run `node script/gen-frontend.mjs`).
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_POOL_ADDRESS=0x...
NEXT_PUBLIC_POLICY_ADDRESS=0x...
NEXT_PUBLIC_TREASURY_ADDRESS=0x...
NEXT_PUBLIC_ORACLE_ADDRESS=0x...

# ---- LI.FI (cross-chain deposits, optional/stretch) ----
NEXT_PUBLIC_LIFI_INTEGRATOR=sentinel
