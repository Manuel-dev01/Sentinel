{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["hardhat.config.ts", "script/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "frontend", "dist", "out", "cache-hardhat", "artifacts"]
}
